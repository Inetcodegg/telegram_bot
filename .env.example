# @BotFather'dan olingan bot tokeni. initData imzosini tekshirish uchun majburiy.
TELEGRAM_BOT_TOKEN=

# Admin panelga kira oladigan Telegram user ID'lar (vergul bilan).
# O'z ID'ingizni bilish uchun: Telegram'da @userinfobot ga /start yozing.
ADMIN_IDS=

# Faqat lokal ishlab chiqish uchun! 1 bo'lsa initData imzosi tekshirilmaydi
# va brauzerda soxta user bilan ochish mumkin. Productionda HECH QACHON yoqmang.
DEV_ALLOW_UNSAFE=0
